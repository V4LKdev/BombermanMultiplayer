PROJECT_NAME           = "Bomberman Multiplayer"
PROJECT_BRIEF          = "Authoritative multiplayer networking layer for Bomberman."
OUTPUT_DIRECTORY       = build/docs-doxygen
OUTPUT_LANGUAGE        = English
USE_MDFILE_AS_MAINPAGE = README.md

INPUT                  = README.md \
                         Core \
                         Entities \
                         Managers \
                         Net \
                         Scenes \
                         Server \
                         Sim \
                         Util \
                         Game.h \
                         Game.cpp \
                         Const.h \
                         main.cpp \
                         server_main.cpp \
                         CMakeLists.txt \
                         docs/architecture.md \
                         docs/net-client.md \
                         docs/multiplayer-level-scene.md \
                         docs/networking.md \
                         docs/testing.md \
                         docs/reference.md \
                         docs/project-notes.md \
                         docs/devlog-summary.md
FILE_PATTERNS          = *.h *.cpp *.md
RECURSIVE              = YES
EXCLUDE                = build \
                         third_party \
                         _temp_docs_archive
EXCLUDE_PATTERNS       = */build/* \
                         */third_party/* \
                         */_temp_docs_archive/*

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_MENUS     = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
TREEVIEW_WIDTH         = 335
HTML_HEADER            = docs/theme/header.html
PAGE_OUTLINE_PANEL     = NO

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 2
AUTOLINK_SUPPORT       = YES
IMAGE_PATH             = docs/assets

QUIET                  = NO
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES

GENERATE_TREEVIEW      = YES
SEARCHENGINE           = YES

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = NO
GROUP_GRAPHS           = NO
INCLUDE_GRAPH          = NO
INCLUDED_BY_GRAPH      = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DIRECTORY_GRAPH        = NO

HTML_EXTRA_STYLESHEET  = docs/theme/doxygen-awesome.css \
                         docs/theme/doxygen-awesome-sidebar-only.css \
                         docs/theme/doxygen-awesome-sidebar-only-darkmode-toggle.css \
                         docs/theme/custom.css
HTML_EXTRA_FILES       = docs/theme/doxygen-awesome-darkmode-toggle.js \
                         docs/theme/doxygen-awesome-interactive-toc.js \
                         docs/theme/image-modal.js \
                         docs/assets/diagrams/multiplayer-level-scene-structure-light.svg \
                         docs/assets/diagrams/multiplayer-level-scene-structure-dark.svg \
                         docs/assets/diagrams/multiplayer-level-scene-runtime-flow-light.svg \
                         docs/assets/diagrams/multiplayer-level-scene-runtime-flow-dark.svg \
                         docs/assets/diagrams/net-client-boundaries-light.svg \
                         docs/assets/diagrams/net-client-boundaries-dark.svg \
                         docs/assets/diagrams/net-client-structure-light.svg \
                         docs/assets/diagrams/net-client-structure-dark.svg \
                         docs/assets/diagrams/networking-bootstrap-flow-light.svg \
                         docs/assets/diagrams/networking-bootstrap-flow-dark.svg \
                         docs/assets/diagrams/networking-packet-correction-light.svg \
                         docs/assets/diagrams/networking-packet-correction-dark.svg
